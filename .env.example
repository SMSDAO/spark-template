# ============================================================
# SPARK ENTERPRISE PLATFORM — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# ── App ──────────────────────────────────────────────────────
VITE_APP_NAME=SPARK Enterprise
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development        # development | staging | production

# ── API ──────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000/api
VITE_API_VERSION=v2.1.0

# ── Auth ─────────────────────────────────────────────────────
# Secret used to sign session tokens (server-side only; not exposed to browser)
# SESSION_SECRET=change-me-to-a-long-random-string

# ── Database ─────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/spark_db

# ── GitHub / OAuth (optional) ────────────────────────────────
# VITE_GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ── Observability ────────────────────────────────────────────
VITE_LOG_LEVEL=info             # debug | info | warn | error

# ── Deployment ───────────────────────────────────────────────
# PORT=5173
# HOST=0.0.0.0

# ── Legacy / inherited ───────────────────────────────────────
# (Kept for backward compatibility; may be removed in v2.0.0)
# NEXT_PUBLIC_RPC_URL=https://base-sepolia.publicnode.com
# NEXT_PUBLIC_API_URL=https://demo.castquest.app/api
# NEXT_PUBLIC_ENV=demo
